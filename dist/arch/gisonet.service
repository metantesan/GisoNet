[Unit]
Description=GisoNet local HTTPS dev proxy
Documentation=https://github.com/metantesan/gisonet
After=network.target

[Service]
Type=simple
ExecStart=/usr/bin/gisonet --daemon
Restart=on-failure
RestartSec=3
AmbientCapabilities=CAP_NET_BIND_SERVICE
CapabilityBoundingSet=CAP_NET_BIND_SERVICE
NoNewPrivileges=yes
StateDirectory=gisonet
RuntimeDirectory=gisonet
RuntimeDirectoryPreserve=yes

[Install]
WantedBy=multi-user.target
